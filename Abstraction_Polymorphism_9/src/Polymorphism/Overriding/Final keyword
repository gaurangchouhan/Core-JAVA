9.9 Final keyword

* Parent Class
class Vehicle{
   public final void start() {
   System.out.println("Vehicle is starting...");
   }
}

* Child Class
class Car{
   public void start() {                      ❌ Error kyuki final bolega ki mere hote
   System.out.println(super.getNo0fTires());
   System.out.println ("Car is starting");
   }
